  "i_do": {
    "id": "i_do",
    "stem": "Expand and simplify: (x + 3)(x − 5).",
    "options": {
      "A": "x^2 − 2x − 15",
      "B": "x^2 + 2x − 15",
      "C": "x^2 − 8x − 15",
      "D": "x^2 − 2x + 15",
      "E": "x^2 − 15"
    },
    "correct": "A",
    "explanation": "FOIL then combine: x·x + x·(−5) + 3·x + 3·(−5) = x^2 − 5x + 3x − 15 = x^2 − 2x − 15.",
    "difficulty": "medium",
    "think_aloud_steps": [
      "First: x · x = x^2.",
      "Outer: x · (−5) = −5x. Inner: 3 · x = 3x.",
      "Last: 3 · (−5) = −15.",
      "Combine the middle terms: −5x + 3x = −2x, giving x^2 − 2x − 15."
    ],
    "key_takeaway": "FOIL: multiply every term in the first factor by every term in the second, then collect the like (middle) terms.",
    "topic": "gmat::quant::algebra::algebraic_expressions",
    "source": "GMATWiz authored",
    "official_flag": false,
    "question_type": "Problem Solving"
  },
  "we_do": [
    {
      "id": "we_1",
      "stem": "Simplify: 4(2x − 3) − 2(x − 5).",
      "options": {
        "A": "6x − 2",
        "B": "6x − 22",
        "C": "6x + 2",
        "D": "10x − 2",
        "E": "6x − 7"
      },
      "correct": "A",
      "explanation": "Distribute: 8x − 12 − 2x + 10. Combine: (8x − 2x) + (−12 + 10) = 6x − 2.",
      "difficulty": "easy",
      "scaffold_hints": [
        "Distribute both groups first.",
        "Mind the sign: −2(x − 5) = −2x + 10.",
        "Combine x-terms and constants separately."
      ],
      "immediate_feedback": {
        "if_correct": "Right — 6x − 2.",
        "if_incorrect": "The −2 multiplies BOTH terms, turning −5 into +10. Re-do that distribution."
      },
      "topic": "gmat::quant::algebra::algebraic_expressions",
      "source": "GMATWiz authored",
      "official_flag": false,
      "question_type": "Problem Solving"
    },
    {
      "id": "we_2",
      "stem": "Factor completely: 6x^2 + 9x.",
      "options": {
        "A": "3x(2x + 3)",
        "B": "3(2x^2 + 3x)",
        "C": "x(6x + 9)",
        "D": "3x(2x + 9)",
        "E": "6x(x + 3)"
      },
      "correct": "A",
      "explanation": "GCF of 6x^2 and 9x is 3x: 6x^2 + 9x = 3x(2x + 3).",
      "difficulty": "medium",
      "scaffold_hints": [
        "What is the greatest common factor of 6x^2 and 9x?",
        "Numbers share 3; both terms share an x → 3x.",
        "6x^2 ÷ 3x = 2x and 9x ÷ 3x = 3."
      ],
      "immediate_feedback": {
        "if_correct": "Yes — 3x(2x + 3), fully factored.",
        "if_incorrect": "Pull out the FULL common factor (3x), not just 3 or just x."
      },
      "topic": "gmat::quant::algebra::algebraic_expressions",
      "source": "GMATWiz authored",
      "official_flag": false,
      "question_type": "Problem Solving"
    }
  ],
