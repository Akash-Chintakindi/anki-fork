        {
          "prompt": "Can |x| ever be negative?",
          "answer": "No — it's a distance, so it's ≥ 0.",
          "targets": "range of absolute value"
        },
        {
          "prompt": "Why does |x| = 5 have two solutions?",
          "answer": "Both 5 and −5 are distance 5 from 0.",
          "targets": "distance interpretation"
        }
      ]
