  "i_do": {
    "id": "i_do",
    "stem": "If f(x) = 2x + 3 and g(x) = x^2, what is f(g(2))?",
    "options": {
      "A": "7",
      "B": "11",
      "C": "14",
      "D": "19",
      "E": "49"
    },
    "correct": "B",
    "explanation": "Inside out: g(2) = 2^2 = 4, then f(4) = 2(4) + 3 = 11.",
    "difficulty": "medium",
    "think_aloud_steps": [
      "Composition works from the inside out — do g(2) first.",
      "g(2) = 2^2 = 4.",
      "Now apply f to that result: f(4) = 2·4 + 3 = 11."
    ],
    "key_takeaway": "For f(g(x)), evaluate the inner function first, then substitute that value into the outer function.",
    "topic": "gmat::quant::algebra::functions",
    "source": "GMATWiz authored",
    "official_flag": false,
    "question_type": "Problem Solving"
  },
  "we_do": [
    {
      "id": "we_1",
      "stem": "If f(x) = 3x − 5, find f(−2).",
